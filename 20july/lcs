int LongestConsecutiveSubsequence(int a[], int n) {
    int hash[1001] = {0};
    int i, max = 0, count;
    for(i = 0; i < n; i++)
        hash[a[i]] = 1;
    for(i = 0; i < n; i++) {
        if(hash[a[i] - 1] == 0) {
            int num = a[i];
            count = 0;
            while(hash[num] == 1) {
                count++;
                num++;
            }
            if(count > max)
                max = count;
        }
    }
    return max;
}